APP_NAME="WBooster CRM"
APP_ENV=local
# После key:generate значение будет с base64 и символом + — держите в кавычках
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost:8080

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=wbooster_crm
DB_USERNAME=wbooster
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:5173,127.0.0.1:8080,127.0.0.1:5173

# CRM
LEAD_RETENTION_MONTHS=24
CRM_INBOUND_LOCAL_PREFIX=leads
CRM_INBOUND_DOMAIN=inbound.local
# Секрет для POST /ingest/inbound-email (Mailgun, curl). Пусто = без проверки (только dev)
INBOUND_WEBHOOK_SECRET=

# Яндекс.Метрика Reporting API (v2 — обогащение рекламного канала)
# OAuth: https://oauth.yandex.ru/ — права metrika:read
# METRIKA_REPORTING_ENABLED=false
# METRIKA_OAUTH_TOKEN=
# METRIKA_REPORTING_LANG=ru
# METRIKA_REPORTING_LOG=true

# Production (Dockerfile.prod / Coolify)
# RUN_MIGRATIONS=true
# LOG_LEVEL=warning
# SENTRY_LARAVEL_DSN=
